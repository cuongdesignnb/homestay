# Application Environment
APP_NAME="Homestay Booking System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8765

# Frontend URL
FRONTEND_URL=http://localhost:5174

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=homestay_db
DB_USERNAME=homestay_user
DB_PASSWORD=homestay_secure_pass_2024

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@homestay.com
MAIL_FROM_NAME="${APP_NAME}"

# SePay Configuration
SEPAY_MERCHANT_ID=your_merchant_id
SEPAY_SECRET_KEY=your_secret_key
SEPAY_ENV=sandbox
SEPAY_ENDPOINT_SANDBOX=https://sb.sepay.vn/merchant/checkout
SEPAY_ENDPOINT_PRODUCTION=https://pay.sepay.vn/v1/checkout/init
SEPAY_DESCRIPTION_PREFIX="Homestay booking"

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# JWT Configuration
JWT_SECRET=your-secret-key-here
JWT_TTL=60

# App Locales
DEFAULT_LOCALE=vi
AVAILABLE_LOCALES=vi,en

# File Upload
MAX_UPLOAD_SIZE=10240
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# SEO
SITE_NAME="Homestay Booking"
SITE_DESCRIPTION="Book your perfect homestay with us"
SITE_KEYWORDS="homestay, booking, travel, tours"
